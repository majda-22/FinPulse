# FinPulse environment example
# Copy this file to `.env` and replace placeholder values as needed.
#
# If your teammates are restoring `finpulse_dump.dump` into the local
# docker-compose PostgreSQL service, the defaults below are the simplest
# setup because they match the repo defaults.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finpulse
POSTGRES_USER=finpulse
POSTGRES_PASSWORD=finpulse_secret

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Object storage
# STORAGE_BACKEND can be: local | r2 | s3
# -----------------------------------------------------------------------------
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./data/raw

# Only needed when STORAGE_BACKEND is not local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=finpulse-filings

# -----------------------------------------------------------------------------
# SEC / FRED
# -----------------------------------------------------------------------------
# Use a real email in the SEC user agent.
EDGAR_USER_AGENT=FinPulse YourName your-email@example.com
EDGAR_RATE_LIMIT=8.0

FRED_API_KEY=
FRED_API_BASE=https://api.stlouisfed.org/fred

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
BATCH_SIZE=32

# -----------------------------------------------------------------------------
# Embeddings / LLM provider
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=mistral
MISTRAL_API_KEY=
MISTRAL_EMBEDDING_MODEL=mistral-embed
MISTRAL_API_BASE=https://api.mistral.ai
EMBEDDING_REQUEST_TIMEOUT_SEC=60.0
